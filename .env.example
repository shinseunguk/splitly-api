# application
APP_PORT=3000
NODE_ENV=development

# database (DB_HOST=postgres is docker-compose internal hostname; use localhost for host-side dev)
DB_HOST=postgres
DB_PORT=5432
# DB_PORT_HOST: host-side port exposed by docker-compose (defaults to 5433 to avoid collision with local postgres)
DB_PORT_HOST=5433
DB_USER=splitly
DB_PASSWORD=splitly
DB_NAME=splitly

# typeorm (development only)
TYPEORM_SYNC=true

# CORS (comma separated origins; use * for any during dev)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
